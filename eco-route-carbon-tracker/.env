# Eco-Route Carbon Tracker Configuration
#
# This application uses local EPA-based emission factors for calculating CO2.
# No API key is required - all calculations are performed locally.
#
# Calculation History:
# - All calculations are stored in memory during the session
# - Access history via the "View History" button in the app
# - Clear history anytime from the History dialog
#
# Emission Factors Used (kg CO2e per km):
# - Small Car: 0.25 kg CO2e/km
# - Large Car: 0.31 kg CO2e/km
# - Bus: 0.08 kg CO2e/km
# - Flight: 0.15 kg CO2e/km
#
# Based on EPA standards and carbon accounting best practices.
app_mode=local_with_in_app_history
